{
  "name": "oncehub-ui",
  "version": "11.0.1-beta.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build ui",
    "postbuild": "gulp copy",
    "test": "ng test ui",
    "lint": "ng lint ui --format stylish",
    "prettier": "prettier --list-different \"**/*.{ts,js,css,scss,md,html}\"",
    "fix:prettier": "prettier --write \"**/*.{ts,js,css,scss,md,html}\"",
    "fix:lint": "ng lint ui --fix --format stylish",
    "bundle-styles": "npm run bundle-styles-blue && npm run compile-scss-blue && npm run bundle-styles-green && npm run compile-scss-green",
    "bundle-styles-blue": "scss-bundle -e ./ui/src/components/core/themes/once-ui-theme-blue.scss -o ./dist/ui/themes/once-ui-theme-blue.scss",
    "bundle-styles-green": "scss-bundle -e ./ui/src/components/core/themes/once-ui-theme-green.scss -o ./dist/ui/themes/once-ui-theme-green.scss",
    "compile-scss-blue": "sass ./dist/ui/themes/once-ui-theme-blue.scss ./dist/ui/themes/once-ui-theme-blue.css && node -e \"require('node:fs').rmSync('./dist/ui/themes/once-ui-theme-blue.scss', { force: true })\"",
    "compile-scss-green": "sass ./dist/ui/themes/once-ui-theme-green.scss ./dist/ui/themes/once-ui-theme-green.css && node -e \"require('node:fs').rmSync('./dist/ui/themes/once-ui-theme-green.scss', { force: true })\"",
    "npm-pack": "cd dist/ui && npm pack",
    "package": "npm run build && cp README.md dist/ui/ && npm run bundle-styles && npm run npm-pack",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "build-storybook": "ng run ui:build-storybook",
    "storybook-css": "sass ui/src/components/core/theming/prebuilt:ui/src/stories/styles/themes",
    "storybook": "ng run ui:storybook",
    "deploy-storybook": "npm run storybook-css && storybook-to-ghpages -o out"
  },
  "private": true,
  "overrides": {
    "picomatch@4.0.3": "4.0.4",
    "readdirp": {
      "picomatch": "4.0.4"
    }
  },
  "dependencies": {
    "@angular-devkit/architect": "0.2102.4",
    "@angular-devkit/core": "21.2.4",
    "@angular/animations": "^21.2.6",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "21.2.6",
    "@angular/compiler": "21.2.6",
    "@angular/core": "21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "core-js": "3.39.0",
    "rxjs": "7.8.1",
    "tslib": "2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.4",
    "@angular-eslint/builder": "^21.3.0",
    "@angular-eslint/eslint-plugin": "^21.3.0",
    "@angular-eslint/eslint-plugin-template": "^21.3.0",
    "@angular-eslint/template-parser": "^21.3.0",
    "@angular/build": "^21.2.4",
    "@angular/cli": "^21.2.4",
    "@angular/compiler-cli": "21.2.6",
    "@angular/elements": "^21.2.6",
    "@angular/language-service": "21.2.6",
    "@babel/core": "7.26.0",
    "@compodoc/compodoc": "^1.1.32",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-links": "^10.2.10",
    "@storybook/angular": "^10.2.10",
    "@types/jasmine": "4.3.0",
    "@types/node": "^22.19.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@webcomponents/custom-elements": "1.5.1",
    "babel-loader": "9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "50.2.2",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-storybook": "^10.2.10",
    "gulp": "5.0.0",
    "jasmine-core": "4.1.0",
    "jasmine-spec-reporter": "7.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "3.1.1",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-jasmine": "4.0.1",
    "karma-jasmine-html-reporter": "1.7.0",
    "karma-junit-reporter": "2.0.1",
    "ng-packagr": "21.2.1",
    "prettier": "2.8.0",
    "puppeteer": "24.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "1.98.0",
    "scss-bundle": "3.1.2",
    "storybook": "^10.2.10",
    "tsx": "^4.7.0",
    "typescript": "5.9.3"
  }
}
